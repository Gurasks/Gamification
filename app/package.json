{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy",
    "serve:hosting": "firebase serve --only hosting",
    "lint": "eslint .",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "check:rules": "firebase firestore:rules:check",
    "emulators:start": "firebase emulators:start --only firestore",
    "emulators:test": "firebase emulators:exec --only firestore \"npm test\"",
    "sonar": "sonar-scanner",
    "lint:report": "eslint . --format json --output-file eslint-report.json",
    "type-check": "tsc --noEmit",
    "i18n:types": "i18next-resources-for-ts interface -i ./src/locales/en -o ./src/types/i18n-resources.d.ts",
    "clean:deps": "knip && depcheck"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "firebase": "^12.5.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.513.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jest": "^30.2.0",
    "knip": "^5.88.1",
    "postcss": "^8.5.3",
    "sonarqube-scanner": "^3.0.1",
    "tailwindcss": "^4.1.7",
    "ts-jest": "^29.4.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "testMatch": [
      "<rootDir>/src/**/*.test.{ts,tsx}",
      "<rootDir>/src/**/*.spec.{ts,tsx}",
      "<rootDir>/src/tests/*.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/main.tsx",
      "!src/vite-env.d.ts",
      "!src/types/**",
      "!src/config/**",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/*.spec.{ts,tsx}"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text-summary",
      "html"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
